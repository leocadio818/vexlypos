# =============================================
# CONFIGURACIÓN DEL SERVIDOR LOCAL POS
# =============================================
# Edita este archivo antes de iniciar el sistema

# IP del servidor (cambiar a la IP fija de tu computadora)
# Ejemplo: 192.168.1.100
SERVER_IP=192.168.1.100

# Puerto del servidor web (normalmente 80)
SERVER_PORT=80

# URL completa del servidor (se genera automáticamente)
SERVER_URL=http://${SERVER_IP}:8001

# Clave secreta para tokens JWT (CAMBIAR POR SEGURIDAD)
JWT_SECRET=MiClaveSecretaSuperSegura2024CambiarEsto

# Nombre de la base de datos
DB_NAME=pos_db

# Zona horaria
TZ=America/Santo_Domingo

# =============================================
# NO MODIFICAR DEBAJO DE ESTA LÍNEA
# =============================================
MONGO_URL=mongodb://mongodb:27017
ENVIRONMENT=production
