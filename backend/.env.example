# Backend environment template — copy to backend/.env and fill in per-client values
# DO NOT commit the real backend/.env (it is gitignored)

# --- Core (same across all clients) ---
MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"
CORS_ORIGINS="*"
JWT_SECRET=replace_with_strong_secret

# --- Email ---
RESEND_API_KEY=re_your_resend_api_key
SENDER_EMAIL=onboarding@resend.dev

# --- Supabase (multi-tenant) ---
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_CLIENT_ID=your_client_slug   # e.g. bikerburger, vexlyapp, etc. CHANGE PER POD.

# --- e-CF providers (sandbox/prod credentials per client) ---
ALANUBE_SANDBOX_TOKEN=
ALANUBE_SANDBOX_RNC=
ALANUBE_SANDBOX_URL=https://sand-api.alanube.co

THEFACTORY_SANDBOX_USER=
THEFACTORY_SANDBOX_PASSWORD=
THEFACTORY_SANDBOX_RNC=
THEFACTORY_SANDBOX_URL=https://demoemision.thefactoryhka.com.do
THEFACTORY_COMPANY_NAME=

MULTIPROD_VALIDATOR_URL=https://validator.megaplus.com.do/api/xml/validate/
ECF_ENCRYPTION_KEY=generate_a_fernet_key

# --- Frontend public URL (used by print-agent installer .bat) ---
FRONTEND_PUBLIC_URL=
